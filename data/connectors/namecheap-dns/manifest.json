{
  "id": "namecheap-dns",
  "name": "Namecheap DNS",
  "status": "available",
  "category": "DNS",
  "summary": "Safe DNS query, plan, backup and apply flow for Namecheap host records.",
  "description": "Namecheap DNS is a dedicated connector package for Namecheap host-record operations. Workflows can query current records, render expected records, plan changes, back up the current host set and apply a reviewed DNS update without hard-coding SDK calls in the host app.",
  "uriSchemes": [
    "dns"
  ],
  "routes": [
    "dns://host/records/query/current",
    "dns://host/records/query/expected",
    "dns://host/records/command/plan",
    "dns://host/records/command/backup",
    "dns://host/records/command/apply"
  ],
  "useCases": [
    "Read current Namecheap host records from the API or mock payloads.",
    "Render expected A/AAAA records for domain-check flows.",
    "Generate a DNS change plan from desired records.",
    "Back up Namecheap host records before a change.",
    "Apply reviewed DNS records from a host workflow."
  ],
  "examples": [
    {
      "title": "Plan a DNS update",
      "uri": "dns://host/records/command/plan",
      "payload": {
        "domain": "example.com",
        "current_records": "[{\"Name\":\"@\",\"Type\":\"A\",\"Address\":\"203.0.113.10\"}]",
        "desired_records": "[{\"Name\":\"@\",\"Type\":\"A\",\"Address\":\"203.0.113.11\"}]"
      }
    },
    {
      "title": "Back up records",
      "uri": "dns://host/records/command/backup",
      "payload": {
        "domain": "example.com",
        "current_records": "[{\"Name\":\"@\",\"Type\":\"A\",\"Address\":\"203.0.113.10\"}]"
      }
    },
    {
      "title": "Mock apply a reviewed plan",
      "uri": "dns://host/records/command/apply",
      "payload": {
        "domain": "example.com",
        "confirm": true,
        "mock_apply": true,
        "backup_uri": "artifact://host/namecheap/dns-backup/example.com/REVIEWED",
        "desired_records": "[{\"Name\":\"@\",\"Type\":\"A\",\"Address\":\"203.0.113.11\"}]"
      }
    }
  ],
  "flowExample": [
    "dns://host/records/command/backup",
    "dns://host/records/command/plan",
    "dns://host/records/command/apply"
  ],
  "requires": [
    "python>=3.10",
    "NAMECHEAP_API_USER",
    "NAMECHEAP_API_KEY",
    "NAMECHEAP_USERNAME",
    "NAMECHEAP_CLIENT_IP"
  ],
  "install": {
    "mode": "urirun-extra",
    "pipSpec": "urirun-connector-namecheap-dns @ git+https://github.com/if-uri/urirun-connector-namecheap-dns.git@v0.1.0"
  },
  "adapterKinds": [
    "argv-template"
  ],
  "docsUrl": "https://github.com/if-uri/urirun-connector-namecheap-dns",
  "keywords": [
    "Namecheap",
    "DNS",
    "records",
    "domain",
    "API"
  ],
  "provenance": "verified",
  "publisher": {
    "name": "if-uri",
    "url": "https://ifuri.com",
    "github": "https://github.com/if-uri"
  }
}
