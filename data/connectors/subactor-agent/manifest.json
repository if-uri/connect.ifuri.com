{
  "id": "subactor-agent",
  "name": "Subactor Agent Control Loop",
  "version": "0.1.0",
  "status": "available",
  "category": "Agents",
  "summary": "Control todo-agent execution through bounded loops, cron discovery and deduplicated triggers.",
  "description": "A URI-native control plane for Subactor's doctor, repair and validator fleet. It reuses todo-agent discovery and its validated runner, persists generation and retry feedback, and never accepts commands or repository paths from actor payloads.",
  "uriSchemes": [
    "subactor-agent"
  ],
  "routes": [
    "subactor-agent://host/cycle/command/run",
    "subactor-agent://host/doctor/query/report",
    "subactor-agent://host/loop/session/run",
    "subactor-agent://host/runs/query/list",
    "subactor-agent://host/state/query/status",
    "subactor-agent://host/tasks/query/discover",
    "subactor-agent://host/trigger/event/emit"
  ],
  "useCases": [
    "Run ready todo-agent task packages from a urirun node.",
    "Drive cron-based maintenance without executing the same schedule slot twice.",
    "Queue ticket, repository and webhook triggers with stable idempotency keys.",
    "Inspect control-loop generations, run receipts and deterministic retry backoff."
  ],
  "examples": [
    {
      "title": "Preview a cron control cycle",
      "uri": "subactor-agent://host/cycle/command/run",
      "payload": {
        "trigger": "schedule",
        "execute": false,
        "max_tasks": 3
      }
    },
    {
      "title": "Queue a Planfile ticket trigger",
      "uri": "subactor-agent://host/trigger/event/emit",
      "payload": {
        "kind": "ticket",
        "event_id": "planfile-PLF-123",
        "task_id": "0042_customer-mail-triage",
        "context": {
          "ticket_id": "PLF-123"
        }
      }
    }
  ],
  "flowExample": [
    "subactor-agent://host/trigger/event/emit",
    "subactor-agent://host/loop/session/run",
    "subactor-agent://host/runs/query/list"
  ],
  "requires": {
    "system": [],
    "python": [
      "python>=3.11",
      "urirun>=0.4.190"
    ],
    "optional": [
      "ifuri-todo-agent>=0.14.3 on the execution node"
    ]
  },
  "install": {
    "mode": "urirun-extra",
    "pipSpec": "urirun-connector-subactor-agent @ git+https://github.com/urirun-connectors/urirun-connector-subactor-agent.git@v0.1.0"
  },
  "adapterKinds": [
    "local-function"
  ],
  "docsUrl": "https://github.com/urirun-connectors/urirun-connector-subactor-agent",
  "keywords": [
    "subactor",
    "agents",
    "todo-agent",
    "cron",
    "triggers",
    "control-loop",
    "urirun"
  ],
  "provenance": "verified",
  "publisher": {
    "name": "urirun-connectors",
    "url": "https://github.com/urirun-connectors",
    "github": "https://github.com/urirun-connectors"
  }
}
