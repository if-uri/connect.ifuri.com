{
  "id": "domain-monitor",
  "name": "Domain Monitor",
  "status": "available",
  "category": "Operations",
  "summary": "HTTP, DNS reads, screenshots, logs and daily domain checks through URI commands.",
  "description": "Domain Monitor is an external urirun connector package for recurring website operations. It generates bindings from decorators, checks HTTP and DNS state, writes logs, stores screenshot metadata and exposes daily check flows through the same URI registry used by MCP and A2A. Provider-specific DNS mutations live in dedicated connectors such as Namecheap DNS.",
  "uriSchemes": [
    "monitor",
    "browser",
    "flow",
    "log"
  ],
  "routes": [
    "monitor://host/http/query/status",
    "monitor://host/dns/query/current",
    "monitor://host/dns/query/expected",
    "browser://host/page/command/screenshot",
    "log://host/daily/command/write",
    "log://host/logs/query/recent",
    "flow://host/domain/command/check",
    "flow://host/daily/command/run"
  ],
  "useCases": [
    "Check if a site responds correctly.",
    "Compare expected and current DNS records.",
    "Record logs and screenshot artifacts from the same domain workflow.",
    "Compose domain checks with provider-specific DNS connectors when a repair is needed.",
    "Expose domain operations to MCP/A2A so LLM agents can discover and call them."
  ],
  "examples": [
    {
      "title": "Check HTTP status",
      "uri": "monitor://host/http/query/status",
      "payload": {
        "domain": "ifuri.com",
        "url": "https://ifuri.com"
      }
    },
    {
      "title": "Read current DNS records",
      "uri": "monitor://host/dns/query/current",
      "payload": {
        "domain": "example.com",
        "record_types": "A,AAAA"
      }
    },
    {
      "title": "Run domain flow",
      "uri": "flow://host/domain/command/check",
      "payload": {
        "domain": "ifuri.com",
        "url": "https://ifuri.com"
      }
    }
  ],
  "flowExample": [
    "monitor://host/http/query/status",
    "monitor://host/dns/query/current",
    "browser://host/page/command/screenshot",
    "log://host/daily/command/write",
    "flow://host/domain/command/check"
  ],
  "requires": [
    "python>=3.10"
  ],
  "install": {
    "mode": "urirun-extra",
    "pipSpec": "urirun-connector-domain-monitor @ git+https://github.com/if-uri/urirun-connector-domain-monitor.git@v0.2.0"
  },
  "adapterKinds": [
    "argv-template"
  ],
  "docsUrl": "https://github.com/if-uri/urirun-connector-domain-monitor",
  "keywords": [
    "domain",
    "monitoring",
    "DNS",
    "HTTP",
    "operations"
  ],
  "provenance": "verified",
  "publisher": {
    "name": "if-uri",
    "url": "https://ifuri.com",
    "github": "https://github.com/if-uri"
  }
}
