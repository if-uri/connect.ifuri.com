{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://connect.ifuri.com/schema/connectors.schema.json",
  "title": "ifuri connect — connector catalog",
  "description": "Schema for data/connectors.json served at /connectors.json.",
  "type": "object",
  "required": ["version", "connectors"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string" },
    "updatedAt": { "type": "string" },
    "defaultPipSpec": { "type": "string" },
    "site": {
      "type": "object",
      "required": ["baseUrl", "title", "description"],
      "properties": {
        "baseUrl": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "ecosystem": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        }
      }
    },
    "connectors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "status", "category", "summary", "description", "uriSchemes", "routes", "install"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "status": { "type": "string", "enum": ["available", "planned"] },
          "category": { "type": "string" },
          "summary": { "type": "string" },
          "description": { "type": "string" },
          "uriSchemes": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9+.-]*$" } },
          "routes": { "type": "array", "items": { "type": "string" } },
          "useCases": { "type": "array", "items": { "type": "string" } },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title", "uri", "payload"],
              "properties": {
                "title": { "type": "string" },
                "uri": { "type": "string" },
                "payload": {}
              }
            }
          },
          "flowExample": { "type": "array", "items": { "type": "string" } },
          "requires": {
            "oneOf": [
              { "type": "array", "items": { "type": "string" } },
              { "type": "object", "additionalProperties": false, "properties": {
                "system": { "type": "array", "items": { "type": "string" } },
                "python": { "type": "array", "items": { "type": "string" } },
                "optional": { "type": "array", "items": { "type": "string" } } } }
            ]
          },
          "install": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": { "type": "string", "enum": ["bundled", "urirun-extra", "planned"] },
              "extra": { "type": "string" },
              "pipSpec": { "type": "string" },
              "pipPackages": { "type": "array", "items": { "type": "string" } }
            }
          },
          "docsUrl": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
