DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^install$ install.php [L,QSA]
  RewriteRule ^submit$ submit.php [L,QSA]
  RewriteRule ^tree$ tree.html [L,QSA]
  RewriteRule ^validate-connector$ api/validate_connector.php [L,QSA]
  RewriteRule ^connectors\.json$ api/connectors.php [L,QSA]
  RewriteRule ^registry\.json$ api/registry.php [L,QSA]
  RewriteRule ^search\.json$ api/search.php [L,QSA]
  RewriteRule ^mcp\.json$ api/mcp.php [L,QSA]
  RewriteRule ^a2a\.json$ api/a2a.php [L,QSA]
  RewriteRule ^\.well-known/agent\.json$ api/a2a.php [L,QSA]
  RewriteRule ^\.well-known/agent-card\.json$ api/a2a.php [L,QSA]
  RewriteRule ^connectors/([a-z0-9._-]+)\.json$ api/connector.php?id=$1 [L,QSA]
  RewriteRule ^connectors/([a-z0-9._-]+)$ connector.php?id=$1 [L,QSA]
  RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]
  RewriteRule ^robots\.txt$ robots.php [L,QSA]
  RewriteRule ^llms\.txt$ llms.php [L,QSA]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
