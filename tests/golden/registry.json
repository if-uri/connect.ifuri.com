        {
            "id": "planfile",
            "name": "Planfile Tasks",
            "status": "available",
            "category": "Planning",
            "summary": "Plan, group and execute daily tasks through task:// and planfile:// URI commands.",
            "description": "Planfile Tasks is an external urirun connector package that turns a local planfile project into URI-addressable work items. It owns ticket list, create, status and DSL routes, generates bindings from decorators, compiles into a normal urirun registry, and projects to MCP tools / A2A skills for host workflows.",
            "uriSchemes": [
                "task",
                "planfile"
            ],
            "routes": [
                "task://host/tickets/query/list",
                "task://host/ticket/query/next",
                "task://host/ticket/query/show",
                "task://host/ticket/command/create",
                "task://host/ticket/command/start",
                "task://host/ticket/command/complete",
                "task://host/ticket/command/fail",
                "task://host/ticket/command/block",
                "task://host/ticket/command/ready",
                "planfile://host/dsl/command/run"
            ],
            "examples": [
                {
                    "title": "List host tickets",
                    "uri": "task://host/tickets/query/list",
                    "payload": {
                        "project": ".",
                        "sprint": "all"
                    }
                },
                {
                    "title": "Create a ticket",
                    "uri": "task://host/ticket/command/create",
                    "payload": {
                        "project": ".",
                        "name": "Check DNS records",
                        "queue": "ops",
                        "prompt": "Check if configured domains resolve and answer with HTTP 200"
                    }
                },
                {
                    "title": "Run planfile DSL",
                    "uri": "planfile://host/dsl/command/run",
                    "payload": {
                        "project": ".",
                        "command": "list tickets sprint=current"
                    }
                }
            ],
            "flowExample": [
                "task://host/ticket/command/create",
                "task://host/ticket/command/start",
                "task://host/ticket/command/complete",
                "task://host/tickets/query/list",
                "planfile://host/dsl/command/run"
            ],
            "install": {
                "mode": "urirun-extra",
                "pipSpec": "urirun-connector-planfile @ git+https://github.com/if-uri/urirun-connector-planfile.git@v0.1.1"
            },
            "docsUrl": "https://github.com/if-uri/urirun-connector-planfile",
            "hubUrl": "https://connect.ifuri.com/connectors/planfile",
            "manifestUrl": "https://connect.ifuri.com/connectors/planfile.json"
        },
        {
            "id": "sqlite-context",
            "name": "SQLite Context Store",
            "status": "available",
            "category": "Data",
            "summary": "Local data, artifacts, checks and logs over data://, artifact://, check:// and log://.",
            "description": "SQLite Context Store is an external urirun connector package that gives the host a small durable memory for records, artifacts, checks and logs. It generates bindings from decorators, compiles into a normal urirun registry, and projects to MCP tools / A2A skills for host workflows that need to remember what was checked, imported, generated or changed.",
            "uriSchemes": [
                "data",
                "artifact",
                "check",
                "log"
            ],
            "routes": [
                "data://host/datasets/query/list",
                "data://host/dataset/command/create",
                "data://host/record/command/upsert",
                "data://host/records/query/search",
                "data://host/sql/query/read-only",
                "artifact://host/artifact/command/register",
                "artifact://host/artifacts/query/list",
                "check://host/check/command/add",
                "check://host/checks/query/recent",
                "log://host/daily/command/write",
                "log://host/logs/query/recent"
            ],
            "examples": [
                {
                    "title": "Create a dataset",
                    "uri": "data://host/dataset/command/create",
                    "payload": {
                        "name": "domains",
                        "dataset_schema": "{\"type\":\"object\",\"required\":[\"domain\"],\"properties\":{\"domain\":{\"type\":\"string\"}}}"
                    }
                },
                {
                    "title": "Upsert local context",
                    "uri": "data://host/record/command/upsert",
                    "payload": {
                        "dataset": "domains",
                        "key": "ifuri.com",
                        "data": "{\"domain\":\"ifuri.com\",\"url\":\"https://ifuri.com\"}"
                    }
                },
                {
                    "title": "Search local context",
                    "uri": "data://host/records/query/search",
                    "payload": {
                        "q": "domain",
                        "limit": 10
                    }
                },
                {
                    "title": "Read recent logs",
                    "uri": "log://host/logs/query/recent",
                    "payload": {
                        "limit": 20
                    }
                }
            ],
            "flowExample": [
                "data://host/dataset/command/create",
                "data://host/record/command/upsert",
                "data://host/records/query/search",
                "artifact://host/artifacts/query/list",
                "log://host/logs/query/recent"
            ],
            "install": {
                "mode": "urirun-extra",
                "pipSpec": "urirun-connector-sqlite-context @ git+https://github.com/if-uri/urirun-connector-sqlite-context.git@v0.1.0"
            },
            "docsUrl": "https://github.com/if-uri/urirun-connector-sqlite-context",
            "hubUrl": "https://connect.ifuri.com/connectors/sqlite-context",
            "manifestUrl": "https://connect.ifuri.com/connectors/sqlite-context.json"
        },
        {
            "id": "domain-monitor",
            "name": "Domain Monitor",
            "status": "available",
            "category": "Operations",
            "summary": "HTTP, DNS, screenshots, logs, Namecheap planning and daily domain checks through URI commands.",
            "description": "Domain Monitor is an external urirun connector package for recurring website operations. It generates bindings from decorators, checks HTTP and DNS state, writes logs, stores screenshot metadata, plans safe Namecheap DNS changes and exposes daily check flows through the same URI registry used by MCP and A2A.",
            "uriSchemes": [
                "monitor",
                "dns",
                "browser",
                "flow",
                "log"
            ],
            "routes": [
                "monitor://host/http/query/status",
                "dns://host/records/query/current",
                "dns://host/records/query/expected",
                "dns://host/records/command/plan",
                "dns://host/records/command/backup",
                "dns://host/records/command/apply",
                "browser://host/page/command/screenshot",
                "log://host/daily/command/write",
                "log://host/logs/query/recent",
                "flow://host/domain/command/check",
                "flow://host/daily/command/run"
            ],
            "examples": [
                {
                    "title": "Check HTTP status",
                    "uri": "monitor://host/http/query/status",
                    "payload": {
                        "domain": "ifuri.com",
                        "url": "https://ifuri.com"
                    }
                },
                {
                    "title": "Plan Namecheap DNS update with mock records",
                    "uri": "dns://host/records/command/plan",
                    "payload": {
                        "domain": "example.com",
                        "provider": "namecheap",
                        "current_records": "[{\"Name\":\"@\",\"Type\":\"A\",\"Address\":\"203.0.113.10\"}]",
                        "desired_records": "[{\"Name\":\"@\",\"Type\":\"A\",\"Address\":\"203.0.113.11\"}]"
                    }
                },
                {
                    "title": "Run domain flow",
                    "uri": "flow://host/domain/command/check",
                    "payload": {
                        "domain": "ifuri.com",
                        "url": "https://ifuri.com"
                    }
                }
            ],
            "flowExample": [
                "monitor://host/http/query/status",
                "dns://host/records/query/current",
                "dns://host/records/command/plan",
                "browser://host/page/command/screenshot",
                "log://host/daily/command/write",
                "flow://host/domain/command/check"
            ],
            "install": {
                "mode": "urirun-extra",
                "pipSpec": "urirun-connector-domain-monitor @ git+https://github.com/if-uri/urirun-connector-domain-monitor.git@v0.1.0"
            },
            "docsUrl": "https://github.com/if-uri/urirun-connector-domain-monitor",
            "hubUrl": "https://connect.ifuri.com/connectors/domain-monitor",
            "manifestUrl": "https://connect.ifuri.com/connectors/domain-monitor.json"
        },
