            "examples": [
                {
                    "title": "Plan a DNS update",
                    "uri": "dns://host/records/command/plan",
                    "payload": {
                        "domain": "example.com",
                        "records": []
                    }
                },
                {
                    "title": "Back up records",
                    "uri": "dns://host/records/command/backup",
                    "payload": {
                        "domain": "example.com"
                    }
                }
            ],
            "flowExample": [
