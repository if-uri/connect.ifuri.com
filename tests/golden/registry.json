                },
                {
                    "title": "Read Warsaw date",
                    "uri": "time://host/clock/query/now",
                    "payload": {
                        "timezone": "Europe/Warsaw",
                        "output": "date"
                    }
                }
            ],
            "flowExample": [
                "time://host/clock/query/now"
            ],
            "install": {
